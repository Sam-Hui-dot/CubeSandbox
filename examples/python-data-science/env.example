# The local E2B-compatible API gateway URL for CubeSandbox
E2B_API_URL="http://127.0.0.1:13000"

# CubeProxy endpoint used by the local dev sidecar for sandbox data-plane traffic
CUBE_REMOTE_PROXY_BASE="https://127.0.0.1:11443"

# The template ID registered using `cubemastercli tpl create-from-image`
CUBE_TEMPLATE_ID="YOUR_DATA_SCIENCE_TEMPLATE_ID"

# Dummy API key used by local CubeSandbox dev endpoints
E2B_API_KEY=e2b_dummyapikeyforlocaltest
